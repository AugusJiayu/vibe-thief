# LLM Provider (至少配一个)
# 默认使用 anthropic provider
LLM_PROVIDER=anthropic

# 方式1: 使用 Anthropic 官方 API
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-sonnet-4-20250514
LLM_VISION_MODEL=claude-sonnet-4-20250514

# 方式2: 使用 OpenAI 兼容 API
# OPENAI_API_KEY=sk-...
# LLM_MODEL=gpt-4o
# LLM_VISION_MODEL=gpt-4o

# 方式3: 使用自定义 endpoint (如 mimo)
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=your-api-key
# LLM_BASE_URL=https://your-endpoint.com/anthropic
# LLM_MODEL=mimo-v2.5-pro
# LLM_VISION_MODEL=mimo-v2.5
